# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DeepSeek or compatible domestic AI model API Key
# Sign up at https://platform.deepseek.com/ or other provider consoles
DEEPSEEK_API_KEY=""

# Base URL for the AI provider (DeepSeek default is shown)
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# The specific model name to use (e.g., deepseek-chat, qwen-max)
DOMESTIC_AI_MODEL="deepseek-chat"
