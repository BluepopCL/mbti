/* pages/index/index.wxss */
.bg-slate { background-color: #0f172a; height: 100vh; color: white; display: flex; flex-direction: column; justify-content: center; align-items: center; }
.hero { text-align: center; margin-bottom: 60rpx; padding: 0 40rpx; }
.title { font-size: 64rpx; font-weight: bold; display: block; margin-bottom: 24rpx; }
.subtitle { font-size: 32rpx; color: #94a3b8; display: block; line-height: 1.5; }
.cards { display: flex; gap: 20rpx; margin-bottom: 80rpx; width: 100%; padding: 0 40rpx; box-sizing: border-box; }
.card { flex: 1; background: rgba(255,255,255,0.05); padding: 30rpx; border-radius: 20rpx; border: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: column; align-items: flex-start; }
.emoji { font-size: 48rpx; margin-bottom: 16rpx; }
.card-title { font-size: 28rpx; font-weight: bold; margin-bottom: 8rpx; }
.card-desc { font-size: 24rpx; color: #cbd5e1; }
.btn-start { background-color: #3b82f6; color: white; border-radius: 60rpx; padding: 24rpx 60rpx; font-size: 36rpx; font-weight: bold; display: flex; align-items: center; gap: 16rpx; box-shadow: 0 10rpx 30rpx rgba(59, 130, 246, 0.4); }
.icon { font-size: 40rpx; }
