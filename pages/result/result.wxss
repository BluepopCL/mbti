.container { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: #f8fafc; padding: 40rpx; }
.loading-box { text-align: center; }
.loading-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; animation: pulse 2s infinite; }
.loading-text { font-size: 32rpx; color: #64748b; font-weight: bold; }
.error-box { text-align: center; }
.error-title { font-size: 40rpx; font-weight: bold; color: #1e293b; margin-bottom: 20rpx; display: block; }
.error-desc { font-size: 28rpx; color: #64748b; margin-bottom: 60rpx; display: block; line-height: 1.5; }
.btn-retry, .btn-home, .btn-share { border-radius: 60rpx; font-weight: bold; font-size: 32rpx; padding: 24rpx 0; width: 100%; margin-bottom: 24rpx; text-align: center;}
.btn-retry, .btn-home { background: #1e293b; color: white; }
.btn-share { background: #10b981; color: white; }

.result-scroll { height: 100vh; background: #f8fafc; }
.result-header { padding: 80rpx 40rpx; text-align: center; background: #0f172a; color: white; border-bottom-left-radius: 60rpx; border-bottom-right-radius: 60rpx; margin-bottom: 40rpx; }
.avatar { width: 240rpx; height: 240rpx; margin: 0 auto 30rpx; display: block; }
.type-id { font-size: 80rpx; font-weight: 900; display: block; text-transform: uppercase; margin-bottom: 10rpx; }
.type-name { font-size: 40rpx; font-weight: bold; display: block; margin-bottom: 10rpx; }
.type-en { font-size: 28rpx; color: #94a3b8; font-style: italic; display: block; }

.card { background: white; border-radius: 30rpx; padding: 40rpx; margin: 0 30rpx 30rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); }
.card-title { font-size: 32rpx; font-weight: bold; margin-bottom: 24rpx; color: #1e293b; border-bottom: 2rpx solid #f1f5f9; padding-bottom: 16rpx;}
.text-green { color: #059669; border-color: #d1fae5; }
.text-orange { color: #ea580c; border-color: #ffedd5; }
.text-blue { color: #2563eb; border-color: #dbeafe; }
.text-pink { color: #db2777; border-color: #fce7f3; }

.summary-text { font-size: 30rpx; color: #475569; line-height: 1.6; display: block;}
.list-item { font-size: 28rpx; color: #475569; display: block; margin-bottom: 16rpx; line-height: 1.5;}
.tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag { background: #f1f5f9; color: #334155; padding: 10rpx 24rpx; border-radius: 40rpx; font-size: 26rpx; font-weight: 500;}

.compat-item { font-size: 28rpx; margin-bottom: 16rpx; color: #475569; }
.bold { font-weight: bold; color: #1e293b; }

.motto-box { text-align: center; padding: 40rpx 60rpx 60rpx; }
.motto-label { font-size: 24rpx; color: #94a3b8; text-transform: uppercase; letter-spacing: 4rpx; margin-bottom: 20rpx; display: block; }
.motto-text { font-size: 40rpx; color: #1e293b; font-weight: bold; font-family: serif; font-style: italic; }

.bottom-actions { padding: 0 40rpx 80rpx; }
@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }
